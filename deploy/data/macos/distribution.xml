<?xml version="1.0" encoding="UTF-8"?>
<installer-gui-script minSpecVersion="1">
    <title>VPNNaruzhu Installer</title>
    <license file="LICENSE"/>
    <choices-outline>
        <line choice="install"/>
        <line choice="uninstall"/>
    </choices-outline>
    <choice id="install" title="Install VPNNaruzhu" start_selected="true">
        <pkg-ref id="org.vpnnaruzhu.package"/>
    </choice>
    <choice id="uninstall" title="Uninstall VPNNaruzhu" start_selected="false">
        <pkg-ref id="org.vpnnaruzhu.uninstall"/>
    </choice>
    <pkg-ref id="org.vpnnaruzhu.package" auth="Root" install-check="scripts/check_install.sh">VPNNaruzhu_install.pkg</pkg-ref>
    <pkg-ref id="org.vpnnaruzhu.uninstall" auth="Root" install-check="scripts/check_uninstall.sh">VPNNaruzhu_uninstall_component.pkg</pkg-ref>
</installer-gui-script>
